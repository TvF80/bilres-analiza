# FinScopePL / BilRes — zmienne środowiskowe
# Skopiuj ten plik jako .env.local i uzupełnij wartości.
# NIGDY nie commituj .env.local do repozytorium.

# ── Supabase (Sesja 1 — auth i baza danych) ────────────────────────────────
# Pobierz z: https://supabase.com/dashboard → projekt → Settings → API
# Zmienne VITE_* są bezpieczne do użycia we frontendzie (tylko anon key, nigdy service_role key)
VITE_SUPABASE_URL=https://tococygjwmbxppzzyotb.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Claude AI (Sesja 6 — funkcja Analiza AI) ───────────────────────────────
# TYLKO po stronie serwera (Vercel Serverless Function api/analyze.ts)
# NIE DODAWAJ prefixu VITE_ — klucz nie może trafić do bundle frontendu
# Ustaw w: https://vercel.com/dashboard → projekt → Settings → Environment Variables
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Sentry error monitoring (opcjonalne) ───────────────────────────────────
# Pobierz DSN z: https://sentry.io → projekt → Settings → Client Keys
# Aktywuje się tylko gdy zmienna jest ustawiona. Bezpieczne — DSN jest publiczny.
# @sentry/react jest już zainstalowany (src/main.tsx) — wystarczy ustawić DSN.
# VITE_SENTRY_DSN=https://abc123@o0.ingest.sentry.io/000000
